DataQuery {
    package 'inventory.management.system'
    name 'AllStockAlerts'
    query `StockAlert.all
    .where((row) => row.organization == inputs.organization)
    .orderBy((row) => row.createdAt, asc: false)`
    inputs [
        {
            name 'organization'
            type Organization
            required true
        }
    ]
    enableSync true
    needCount true
}
