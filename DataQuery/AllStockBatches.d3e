DataQuery {
    package 'inventory.management.system'
    name 'AllStockBatches'
    query `StockBatch.all
    .where((row) => row.organization == inputs.organization)
    .orderBy((row) => row.batchNumber, asc: true)`
    inputs [
        {
            name 'organization'
            type Organization
            required true
        }
    ]
    enableSync true
    needCount true
}
