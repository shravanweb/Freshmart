Page {
    package 'inventory.management.system'
    name 'MovementReportPage'
    description 'Inventory movement report with date range filter'
    properties [
        {
            name 'user'
            type User
            required true
        }
        {
            name 'userProfileData'
            type UserProfileByUser
            computed true
            computation `Query.getUserProfileByUser(UserProfileByUserRequest(user: user)).await`
            internal true
            synchronise true
        }
        {
            name 'userProfile'
            type UserProfile
            computed true
            computation `userProfileData != null ? userProfileData.items.first : null`
            internal true
        }
        {
            name 'organization'
            type Organization
            computed true
            computation `userProfile != null ? userProfile.organization : null`
            internal true
        }
        {
            name 'startDate'
            type DateTime
            internal true
            defaultValue `DateTime.now().subtract(Duration(days: 30))`
        }
        {
            name 'endDate'
            type DateTime
            internal true
            defaultValue `DateTime.now()`
        }
        {
            name 'reportData'
            type MovementReportRows
            computed true
            computation `organization != null ? Query.getMovementReportRows(MovementReportRowsRequest(organization: organization, startDate: startDate, endDate: endDate)).await : null`
            internal true
            synchronise true
        }
        {
            name 'reportItems'
            type InventoryMovement
            collection true
            computed true
            computation `reportData != null ? reportData.items : []`
            internal true
        }
        {
            name 'rowCountLabel'
            type String
            computed true
            computation `reportData != null ? reportData.count.toString() + ' movements' : '0 movements'`
            internal true
        }
        {
            name 'reportExportRows'
            type String
            collection true
            computed true
            computation `reportItems.map((row) => row.movementDate.toString() + ',' + row.product.name + ',' + row.warehouse.name + ',' + row.movementType.toString() + ',' + row.direction.toString() + ',' + row.quantity.toString()).toList()`
            internal true
        }
    ]
    build Container {
        name 'pageRootRef'
        styles [
            PageBackgroundStyle
            GlassPanelStyle
            GlassCardStyle
            GlassSidebarStyle
            PrimaryButtonStyle
            FormFieldStyle
        ]
        tags [
            'pageBackground'
        ]
        child Row {
            name 'shellRowRef'
            data {
                mainAxisSize 'max'
                crossAxisAlignment 'stretch'
            }
            children [
                IMSidebarWidget {
                    name 'sidebarRef'
                    data {
                        currentUser `user`
                        userProfile `userProfile`
                    }
                }
                Container {
                    name 'mainRef'
                    data {
                        expand 'true'
                    }
                    child Column {
                        name 'mainColumnRef'
                        data {
                            crossAxisAlignment 'stretch'
                            mainAxisSize 'max'
                        }
                        children [
                            IMSAppHeaderWidget {
                                name 'headerRef'
                                data {
                                    title 'Movement Report'
                                    organization `organization`
                                }
                            }
                            Container {
                                name 'contentRef'
                                tags [
                                    'pageContent'
                                ]
                                data {
                                    expand 'true'
                                    vscroll 'true'
                                    padding '24'
                                }
                                child Column {
                                    name 'contentColumnRef'
                                    data {
                                        crossAxisAlignment 'stretch'
                                    }
                                    children [
                                        Row {
                                            name 'titleRowRef'
                                            data {
                                                mainAxisAlignment 'spaceBetween'
                                                crossAxisAlignment 'center'
                                                mainAxisSize 'max'
                                            }
                                            children [
                                                TextView {
                                                    name 'pageTitleRef'
                                                    data {
                                                        data 'Inventory Movement Report'
                                                        textStyle {
                                                            color '@c4'
                                                            fontSize '24'
                                                            fontWeight 'w700'
                                                        }
                                                    }
                                                }
                                                ReportExportButtonWidget {
                                                    name 'exportRef'
                                                    data {
                                                        reportData `reportExportRows`
                                                    }
                                                }
                                            ]
                                        }
                                        Container {
                                            name 'filterSpacerRef'
                                            data {
                                                margin '0 0 16 0'
                                            }
                                        }
                                        DateRangeFilterWidget {
                                            name 'dateFilterRef'
                                        }
                                        Container {
                                            name 'tableSpacerRef'
                                            data {
                                                margin '0 0 16 0'
                                            }
                                        }
                                        Container {
                                            name 'tableCardRef'
                                            tags [
                                                'glassCardFlat'
                                            ]
                                            child Column {
                                                name 'tableColumnRef'
                                                data {
                                                    crossAxisAlignment 'stretch'
                                                }
                                                children [
                                                    TextView {
                                                        name 'tableTitleRef'
                                                        data {
                                                            data 'Movement Rows'
                                                            margin '0 0 8 0'
                                                            textStyle {
                                                                color '@c4'
                                                                fontSize '18'
                                                                fontWeight 'w600'
                                                            }
                                                        }
                                                    }
                                                    TextView {
                                                        name 'tableCountRef'
                                                        data {
                                                            data `rowCountLabel`
                                                            margin '0 0 16 0'
                                                            textStyle {
                                                                color '@c5'
                                                                fontSize '13'
                                                            }
                                                        }
                                                    }
                                                    Container {
                                                        name 'tableRef'
                                                        tags [
                                                            'glassPanel'
                                                        ]
                                                        data {
                                                            padding '16'
                                                        }
                                                        child TextView {
                                                            name 'tableHintRef'
                                                            data {
                                                                data 'Bind movement rows from MovementReportRows query'
                                                                textStyle {
                                                                    color '@c5'
                                                                    fontSize '14'
                                                                }
                                                            }
                                                        }
                                                    }
                                                ]
                                            }
                                        }
                                    ]
                                }
                            }
                        ]
                    }
                }
            ]
        }
    }
    eventHandlers [
        {
            name 'onLogoutHandler'
            type OnEvent
            on headerRef
            event onLogout
            block ```
                navigator.pushLoginPage(target: 'main', replace: true);
            ```
        }
        {
            name 'onProfileHandler'
            type OnEvent
            on headerRef
            event onProfile
            block ```
                navigator.pushProfileSettingsPage(user: user, target: 'main', replace: false);
            ```
        }
        {
            name 'onNavigateHandler'
            type OnEvent
            on sidebarRef
            event onNavigate
            block ```
                if (route == '/dashboard') {
                    navigator.pushDashboardPage(user: user, target: 'main', replace: true);
                } else if (route == '/reports/stock-valuation') {
                    navigator.pushStockValuationReportPage(user: user, target: 'main', replace: true);
                }
            ```
        }
        {
            name 'onDateRangeChangedHandler'
            type OnEvent
            on dateFilterRef
            event onChange
            block ```
                startDate = filterStart;
                endDate = filterEnd;
            ```
        }
    ]
}
