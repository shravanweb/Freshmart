	getVerificationDataById ( id: Long ) : VerificationData
	getWarehouseById ( id: Long ) : Warehouse
	getWarehouseStockById ( id: Long ) : WarehouseStock
	getAllAuditLogs ( in: AllAuditLogsIn ) : AllAuditLogs
	getAllGoodsReceipts ( in: AllGoodsReceiptsIn ) : AllGoodsReceipts
	getAllInAppNotifications ( in: AllInAppNotificationsIn ) : AllInAppNotifications
	getAllInventoryAdjustments ( in: AllInventoryAdjustmentsIn ) : AllInventoryAdjustments
	getAllInventoryMovements ( in: AllInventoryMovementsIn ) : AllInventoryMovements
	getAllOrganizations : AllOrganizations
	getAllProductCategories ( in: AllProductCategoriesIn ) : AllProductCategories
	getAllProducts ( in: AllProductsIn ) : AllProducts
	getAllPurchaseOrders ( in: AllPurchaseOrdersIn ) : AllPurchaseOrders
