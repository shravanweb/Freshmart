	getOutOfStockItems ( in: OutOfStockItemsIn ) : OutOfStockItems
	getProductItem ( in: ProductItemIn ) : ProductItem
	getProductSearch ( in: ProductSearchIn ) : ProductSearch
	getProductsByCategory ( in: ProductsByCategoryIn ) : ProductsByCategory
	getPurchaseOrderItem ( in: PurchaseOrderItemIn ) : PurchaseOrderItem
	getPurchaseOrdersByStatus ( in: PurchaseOrdersByStatusIn ) : PurchaseOrdersByStatus
	getSalesOrderItem ( in: SalesOrderItemIn ) : SalesOrderItem
	getSalesOrdersByStore ( in: SalesOrdersByStoreIn ) : SalesOrdersByStore
	getStockTransferItem ( in: StockTransferItemIn ) : StockTransferItem
	getStockValuationReport ( in: StockValuationReportIn ) : StockValuationReport
