scalar Date

scalar LocalDate

scalar LocalDateTime

scalar LocalTime

scalar OffsetDateTime

scalar ExpressionString

scalar BlockString

scalar Type

scalar Duration

schema
{
	query: Query
	mutation: Mutation
}

union BaseUserUnionX =  AnonymousUser | User

union ReportBaseConfigUnionX =  ReportBarChartConfig | ReportCardConfig | ReportFunnelChartConfig | ReportGuageConfig | ReportKPIConfig | ReportKeyInfluencerConfig | ReportLineAndAreaChartConfig | ReportLineAndColumnChartConfig | ReportMapConfig | ReportMatrixConfig | ReportMultiRowCardConfig | ReportPieChartConfig | ReportScatterChartConfig | ReportSlicerConfig | ReportTableConfig | ReportWaterfallChartConfig

union ReportFilterUnionX =  ReportNamedConditionFilter | ReportPropertyFilter

union ReportRuleUnionX =  ReportRuleSet | ReportSingleRule

interface DBObject
{
	id : Long
	localId : Long
}

type DatabaseObject
{
	object : DBObject
}

type DFile
{
	name : String
	id : String
	size : Long
}

input DFileEntityInput
{
	name : String
	id : String
	size : Long
}

type LoginResult
{
	success : Boolean
	token : String
	failureMessage : String
	userObject : UserUnionX
}

input ObjectRef
{
	id : Long
	type : String
}

type Query
{
	getObject : DatabaseObject
	getAnonymousUserById ( id: Long ) : AnonymousUser
	getAuditLogById ( id: Long ) : AuditLog
	getGoodsReceiptById ( id: Long ) : GoodsReceipt
	getGoodsReceiptLineById ( id: Long ) : GoodsReceiptLine
	getInAppNotificationById ( id: Long ) : InAppNotification
	getInventoryAdjustmentById ( id: Long ) : InventoryAdjustment
	getInventoryAdjustmentLineById ( id: Long ) : InventoryAdjustmentLine
	getInventoryMovementById ( id: Long ) : InventoryMovement
	getNotificationTemplateById ( id: Long ) : NotificationTemplate
	getOneTimePasswordById ( id: Long ) : OneTimePassword
	getOrganizationById ( id: Long ) : Organization
	getProductById ( id: Long ) : Product
	getProductCategoryById ( id: Long ) : ProductCategory
	getPurchaseOrderById ( id: Long ) : PurchaseOrder
	getPurchaseOrderLineById ( id: Long ) : PurchaseOrderLine
	getPushNotificationById ( id: Long ) : PushNotification
	getReportById ( id: Long ) : Report
	getSalesOrderById ( id: Long ) : SalesOrder
	getSalesOrderLineById ( id: Long ) : SalesOrderLine
	getSalesReturnById ( id: Long ) : SalesReturn
	getSalesReturnLineById ( id: Long ) : SalesReturnLine
	getStockAlertById ( id: Long ) : StockAlert
	getStockBatchById ( id: Long ) : StockBatch
	getStockTransferById ( id: Long ) : StockTransfer
