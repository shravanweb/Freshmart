	loginWithOTP ( token: String code: String ) : LoginResult
	registerInventoryManagementSystemUser ( displayName: String email: String password: String appRole: AppUserRole ) : LoginResult
	createStaffUser ( displayName: String email: String password: String appRole: AppUserRole ) : LoginResult
	sendInventoryManagementSystemPasswordResetOtp ( email: String ) : LoginResult
	resetInventoryManagementSystemPasswordWithOtp ( token: String code: String newPassword: String ) : LoginResult
}

