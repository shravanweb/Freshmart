	getAllStockAlerts ( in: AllStockAlertsIn ) : AllStockAlerts
	getAllStockBatches ( in: AllStockBatchesIn ) : AllStockBatches
	getAllStockTransfers ( in: AllStockTransfersIn ) : AllStockTransfers
	getAllStores ( in: AllStoresIn ) : AllStores
	getAllSuppliers ( in: AllSuppliersIn ) : AllSuppliers
	getAllUnitOfMeasures ( in: AllUnitOfMeasuresIn ) : AllUnitOfMeasures
	getAllUserInvitations ( in: AllUserInvitationsIn ) : AllUserInvitations
	getAllUserProfiles ( in: AllUserProfilesIn ) : AllUserProfiles
	getAllWarehouses ( in: AllWarehousesIn ) : AllWarehouses
	getDashboardMetrics ( in: DashboardMetricsIn ) : DashboardMetrics
	getExpiringBatches ( in: ExpiringBatchesIn ) : ExpiringBatches
	getGoodsReceiptItem ( in: GoodsReceiptItemIn ) : GoodsReceiptItem
	getInventoryMovementsByDateRange ( in: InventoryMovementsByDateRangeIn ) : InventoryMovementsByDateRange
	getLowStockItems ( in: LowStockItemsIn ) : LowStockItems
	getMovementReportRows ( in: MovementReportRowsIn ) : MovementReportRows
