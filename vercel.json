{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix build/InventoryManagementSystem",
  "buildCommand": "node scripts/write-production-settings.js && npm run build --prefix build/InventoryManagementSystem",
  "outputDirectory": "build/InventoryManagementSystem/build",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
